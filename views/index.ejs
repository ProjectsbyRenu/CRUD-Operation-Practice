<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="h-full bg-zinc-900 text-white px-5">
<div class="py-5">
    <div class="text-blue-500 mb-5">
        <a href="/read">Read users</a>
    </div>
    <h1 class="text-xl font-bold mb-4">Create Users</h1>
  <form action="/create" method="post">
    <input class="px-5 py-2 bg-zinc-600 rounded" type="text" placeholder="name" name="name">
    <input class="px-5 py-2 bg-zinc-600 rounded" type="text" placeholder="email" name="email">
    <input class="px-5 py-2 bg-zinc-600 rounded" type="text" placeholder="image url" name="image">
    <input class="bg-blue-600 px-5 py-2 rounded" type="submit" value="Create User" >
  </form>
</div>
</body>
</html>